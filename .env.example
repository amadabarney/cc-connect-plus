# feishuAdapter 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 飞书应用凭证（必需）
# ============================================
# 在飞书开放平台创建企业自建应用后获取
# https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Agent 进程池配置（可选）
# ============================================
# 最大同时运行的 Agent 数量
MAX_AGENTS=5

# Agent 闲置超时时间（秒）
# 超过此时间未活动的 Agent 会被自动停止
IDLE_TIMEOUT=7200

# ============================================
# 用户权限控制（可选）
# ============================================
# 允许使用的飞书用户 ID 列表（逗号分隔）
# 留空表示允许所有用户
ALLOWED_USERS=ou_xxxxx,ou_yyyyy

# 管理员用户 ID 列表（逗号分隔）
# 管理员可以执行删除项目等敏感操作
ADMIN_USERS=ou_xxxxx

# ============================================
# 系统配置（可选）
# ============================================
# 时区设置
TZ=Asia/Shanghai

# 项目工作空间根目录
WORKSPACE_DIR=~/projects

# 配置文件路径（如果使用 TOML 配置）
# CONFIG_FILE=./config.toml

# ============================================
# API Keys（如果使用中转服务）
# ============================================
# 这些通常不需要，因为 CLI 工具使用 OAuth 认证
# 但如果配置了中转服务，可以在这里设置

# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
